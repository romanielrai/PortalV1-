generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  name          String?
  passwordHash  String
  suspended     Boolean      @default(false)
  role          Role         @relation(fields: [roleId], references: [id])
  roleId        String
  client        Client?      @relation(fields: [clientId], references: [id])
  clientId      String?      
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  leads         Lead[]
  appointments  Appointment[]
  auditLogs     AuditLog[]
  chatbotLogs   ChatbotLog[]
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  users       User[]
  permissions Permission[] @relation("RolePermissions")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  roles       Role[]   @relation("RolePermissions")
}

model Client {
  id             String        @id @default(uuid())
  companyName    String
  contactName    String
  contactEmail   String
  contactPhone   String
  plan           String        @default("STARTER")
  industry       String?
  status         String        @default("ACTIVE")
  userAccounts   User[]
  leads          Lead[]
  appointments   Appointment[]
  campaigns      Campaign[]
  calls          Call[]
  smsMessages    SMS[]
  emails         Email[]
  subscriptions  Subscription[]
  invoices       Invoice[]
  payments       Payment[]
  voiceLogs      VoiceLog[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Lead {
  id          String      @id @default(uuid())
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId      String?
  name        String
  email       String
  phone       String
  business    String
  status      String      @default("NEW")
  source      String
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  appointments Appointment[]
  chatbotLogs  ChatbotLog[]
  calls       Call[]
  sms         SMS[]
  emails      Email[]
}

model Appointment {
  id          String    @id @default(uuid())
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String
  lead        Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  leadId      String?
  title       String
  scheduledAt DateTime
  status      String    @default("PENDING")
  notes       String?
  createdBy   User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Campaign {
  id          String    @id @default(uuid())
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String
  name        String
  type        String    @default("LEAD_REACTIVATION")
  status      String    @default("ACTIVE")
  startDate   DateTime
  endDate     DateTime?
  budget      Float?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Call {
  id            String      @id @default(uuid())
  client        Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId      String
  lead          Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)
  leadId        String?
  initiatedBy   String
  durationSec   Int
  outcome       String
  recordingUrl  String?
  createdAt     DateTime    @default(now())
}

model SMS {
  id          String   @id @default(uuid())
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  leadId      String?
  body        String
  status      String
  sentAt      DateTime @default(now())
}

model Email {
  id          String   @id @default(uuid())
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  leadId      String?
  subject     String
  body        String
  status      String
  openRate    Float?   @default(0)
  clickRate   Float?   @default(0)
  sentAt      DateTime @default(now())
}

model Subscription {
  id          String   @id @default(uuid())
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String
  plan        String   @default("STARTER")
  status      String   @default("ACTIVE")
  startedAt   DateTime @default(now())
  renewsAt    DateTime
}

model Invoice {
  id          String   @id @default(uuid())
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String
  amount      Float
  dueDate     DateTime
  paid        Boolean  @default(false)
  invoiceUrl  String?
  createdAt   DateTime @default(now())
}

model Payment {
  id          String   @id @default(uuid())
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String
  amount      Float
  method      String
  status      String
  paidAt      DateTime @default(now())
}

model ChatbotLog {
  id          String   @id @default(uuid())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  leadId      String?
  sessionId   String
  role        String
  message     String
  metadata    String?
  createdAt   DateTime @default(now())
}

model VoiceLog {
  id          String   @id @default(uuid())
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String
  callId      String?
  transcript  String?
  durationSec Int
  createdAt   DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(uuid())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId      String?
  action      String
  actor       String?
  target      String?
  details     String?
  ipAddress   String?
  createdAt   DateTime @default(now())
}

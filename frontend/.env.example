# ─── Required Vercel Environment Variables ────────────────────────────────────
# Add all of these at: https://vercel.com/portal-v1/portal-v1-frontend/settings/environment-variables

# Supabase Pooled connection (Transaction Mode — port 6543)
POSTGRES_PRISMA_URL="postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
POSTGRES_URL="postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Direct connection (Session Mode — port 5432, used for migrations)
POSTGRES_URL_NON_POOLING="postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Auth secrets
JWT_SECRET="REPLACE_WITH_A_LONG_RANDOM_SECRET"
NEXTAUTH_SECRET="REPLACE_WITH_A_LONG_RANDOM_SECRET"
NEXTAUTH_URL="https://YOUR-VERCEL-URL.vercel.app"
